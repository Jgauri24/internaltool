GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GOOGLE_SHEETS_CREDENTIALS_JSON=./credentials/service-account.json
GOOGLE_SHEET_ID=

# Parallel workers (clamped: MIN_WORKERS <= WORKERS/--workers <= MAX_WORKERS)
MIN_WORKERS=1
MAX_WORKERS=8
WORKERS=1

# Gemini token usage log (JSONL, one line per API call)
TOKEN_LOG_PATH=logs/token_usage.jsonl
